<script>
// ═══════════════════════════════════════════════
//  DATA LAYER
// ═══════════════════════════════════════════════

const DEFAULT_CATEGORIES = [
  { id:'food',      name:'אוכל',         emoji:'🍕' },
  { id:'transport', name:'תחבורה',       emoji:'🚗' },
  { id:'shopping',  name:'קניות',        emoji:'🛍️' },
  { id:'health',    name:'בריאות',       emoji:'💊' },
  { id:'bills',     name:'חשבונות',      emoji:'📄' },
  { id:'salary',    name:'משכורת',       emoji:'💼' },
  { id:'fun',       name:'בילוי',        emoji:'🎮' },
  { id:'education', name:'חינוך',        emoji:'📚' },
  { id:'home',      name:'בית',          emoji:'🏠' },
  { id:'other',     name:'אחר',          emoji:'📌' },
];

const TAGS = ['חיוני','נחמד','אחד-פעמי','חוזר','עבודה','משפחה','בריאות'];

function load(key, def) {
  try { return JSON.parse(localStorage.getItem(key)) ?? def; } catch { return def; }
}
function save(key, val) { localStorage.setItem(key, JSON.stringify(val)); }

let transactions = load('fm_transactions', []);
let categories   = load('fm_categories', DEFAULT_CATEGORIES);
let budgets      = load('fm_budgets', { global: 0, cats: {} });
let currentType  = 'expense';
let currentFilter = 'all';
let editingId    = null;

// charts
let trendChartInst = null, donutChartInst = null, compareChartInst = null;

// ═══════════════════════════════════════════════
//  DATE HELPERS
// ═══════════════════════════════════════════════

function today() { return new Date().toISOString().slice(0,10); }
function nowMs()  { return Date.now(); }
function fmtDate(d) {
  const dt = new Date(d);
  return dt.toLocaleDateString('he-IL', { day:'2-digit', month:'2-digit', year:'2-digit' });
}
function fmtMoney(n) { return '₪' + Math.abs(n).toLocaleString('he-IL', { minimumFractionDigits: 0, maximumFractionDigits: 0 }); }
function monthKey(d) { return d.slice(0,7); }
function currentMonth() { return today().slice(0,7); }
function daysInMonth(ym) { const [y,m]=ym.split('-'); return new Date(y,m,0).getDate(); }
function dayOfMonth() { return new Date().getDate(); }

// ═══════════════════════════════════════════════
//  CATEGORY HELPERS
// ═══════════════════════════════════════════════

function getCat(id) { return categories.find(c=>c.id===id) || {name:id, emoji:'📌'}; }
function catColor(idx) {
  const colors = ['#6c63ff','#38bdf8','#34d399','#fbbf24','#f87171','#a78bfa','#fb923c','#e879f9','#22d3ee','#4ade80'];
  return colors[idx % colors.length];
}

// ═══════════════════════════════════════════════
//  COMPUTED STATS
// ═══════════════════════════════════════════════

function monthTx(ym) { return transactions.filter(t => t.date.startsWith(ym)); }
function totalIncome(txs) { return txs.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0); }
function totalExpense(txs) { return txs.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0); }

function forecast() {
  const txs = monthTx(currentMonth());
  const exp = totalExpense(txs);
  const dom = dayOfMonth();
  const dim = daysInMonth(currentMonth());
  const rate = exp / dom;
  return { rate, projected: rate * dim };
}

function expByCat(txs) {
  const map = {};
  txs.filter(t=>t.type==='expense').forEach(t=>{
    map[t.category] = (map[t.category]||0) + t.amount;
  });
  return map;
}

function todayExpense() {
  return transactions.filter(t=>t.date===today()&&t.type==='expense').reduce((s,t)=>s+t.amount,0);
}

// detect recurring: same description appearing 2+ times
function getRecurring() {
  const freq = {};
  transactions.forEach(t=>{
    const k = t.description.trim().toLowerCase();
    if (!freq[k]) freq[k]={count:0,total:0,items:[]};
    freq[k].count++;
    freq[k].total+=t.amount;
    freq[k].items.push(t);
  });
  return Object.entries(freq).filter(([,v])=>v.count>=2).map(([k,v])=>({desc:k,...v}));
}

// ═══════════════════════════════════════════════
//  RENDER
// ═══════════════════════════════════════════════

function renderAll() {
  renderHero();
  renderDashboard();
  renderTransactions();
  renderAnalysis();
  renderBudget();
  renderInsights();
}

function renderHero() {
  const txs = monthTx(currentMonth());
  const inc = totalIncome(txs);
  const exp = totalExpense(txs);
  const bal = inc - exp;
  const f = forecast();
  document.getElementById('heroIncome').textContent = fmtMoney(inc);
  document.getElementById('heroExpense').textContent = fmtMoney(exp);
  const balEl = document.getElementById('heroBalance');
  balEl.textContent = (bal<0?'-':'') + fmtMoney(bal);
  balEl.className = 'balance-amount ' + (bal>=0?'positive':'negative');
  document.getElementById('heroForecast').textContent = fmtMoney(f.projected);
}

function renderDashboard() {
  const txs = monthTx(currentMonth());
  const exp = totalExpense(txs);
  const inc = totalIncome(txs);
  const f = forecast();

  // forecast
  document.getElementById('forecastEnd').textContent = fmtMoney(f.projected);
  document.getElementById('forecastSub').textContent = `קצב יומי: ${fmtMoney(f.rate)} | יום ${dayOfMonth()} מתוך ${daysInMonth(currentMonth())}`;
  document.getElementById('avgDailyBadge').textContent = `ממוצע יומי: ${fmtMoney(f.rate)}`;

  // quick stats
  document.getElementById('statToday').textContent = fmtMoney(todayExpense());
  document.getElementById('statTxCount').textContent = txs.length;
  const catMap = expByCat(txs);
  const topCat = Object.entries(catMap).sort((a,b)=>b[1]-a[1])[0];
  document.getElementById('statTopCat').textContent = topCat ? getCat(topCat[0]).emoji : '—';
  const savings = inc>0 ? Math.round(((inc-exp)/inc)*100) : 0;
  document.getElementById('statSavings').textContent = savings+'%';

  // recent 5
  const recent = [...transactions].sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0,5);
  const container = document.getElementById('recentTxList');
  if (!recent.length) { container.innerHTML = '<div class="empty-state"><div class="emoji">💸</div><p>אין תנועות עדיין<br>לחץ + כדי להוסיף</p></div>'; return; }
  container.innerHTML = recent.map(t=>txHTML(t)).join('');

  // trend chart
  renderTrendChart();
}

function txHTML(t) {
  const cat = getCat(t.category);
  const sign = t.type==='income' ? '+' : '-';
  const cls  = t.type==='income' ? 'inc' : 'exp';
  return `<div class="tx-item" onclick="openEditModal('${t.id}')">
    <div class="tx-icon" style="background:${t.type==='income'?'rgba(52,211,153,0.15)':'rgba(248,113,113,0.1)'}">${cat.emoji}</div>
    <div class="tx-info">
      <div class="tx-title">${t.description || cat.name}</div>
      <div class="tx-meta">${cat.name} · ${fmtDate(t.date)}${t.tags&&t.tags.length?' · '+t.tags.join(', '):''}</div>
    </div>
    <div class="tx-amount ${cls}">${sign}${fmtMoney(t.amount)}</div>
  </div>`;
}

function renderTransactions() {
  let txs = [...transactions];
  const q = document.getElementById('searchInput').value.toLowerCase();
  if (q) txs = txs.filter(t=>(t.description||'').toLowerCase().includes(q) || getCat(t.category).name.toLowerCase().includes(q));
  if (currentFilter==='income')  txs = txs.filter(t=>t.type==='income');
  if (currentFilter==='expense') txs = txs.filter(t=>t.type==='expense');

  const sort = document.getElementById('sortSelect').value;
  if (sort==='date-desc')   txs.sort((a,b)=>new Date(b.date)-new Date(a.date));
  if (sort==='date-asc')    txs.sort((a,b)=>new Date(a.date)-new Date(b.date));
  if (sort==='amount-desc') txs.sort((a,b)=>b.amount-a.amount);
  if (sort==='amount-asc')  txs.sort((a,b)=>a.amount-b.amount);

  const container = document.getElementById('txList');
  if (!txs.length) { container.innerHTML = '<div class="empty-state"><div class="emoji">📂</div><p>לא נמצאו תנועות</p></div>'; return; }
  container.innerHTML = txs.map(t=>txHTML(t)).join('');
}

function renderAnalysis() {
  const txs = monthTx(currentMonth());
  const catMap = expByCat(txs);
  const total = Object.values(catMap).reduce((s,v)=>s+v,0);
  document.getElementById('donutTotal').textContent = fmtMoney(total);

  const entries = Object.entries(catMap).sort((a,b)=>b[1]-a[1]);
  const colors = entries.map((_,i)=>catColor(i));

  // Donut chart
  if (donutChartInst) donutChartInst.destroy();
  const ctx = document.getElementById('donutChart').getContext('2d');
  donutChartInst = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: entries.map(([id])=>getCat(id).name),
      datasets: [{
        data: entries.map(([,v])=>v),
        backgroundColor: colors,
        borderWidth: 0,
        hoverOffset: 6
      }]
    },
    options: {
      cutout:'70%', responsive:false,
      plugins:{ legend:{display:false}, tooltip:{
        callbacks:{ label: ctx => ` ${fmtMoney(ctx.raw)} (${Math.round(ctx.raw/total*100)}%)` }
      }}
    }
  });

  // Legend
  const legend = document.getElementById('donutLegend');
  if (!entries.length) { legend.innerHTML = '<div style="color:var(--text2);font-size:12px">אין נתונים לחודש זה</div>'; return; }
  legend.innerHTML = entries.slice(0,6).map(([id,val],i)=>`
    <div class="legend-item">
      <div class="legend-dot" style="background:${colors[i]}"></div>
      <div class="legend-name">${getCat(id).emoji} ${getCat(id).name}</div>
      <div class="legend-pct">${Math.round(val/total*100)}%</div>
      <div class="legend-val">${fmtMoney(val)}</div>
    </div>`).join('');

  // Compare chart (last 6 months)
  renderCompareChart();

  // Recurring
  const recs = getRecurring();
  const recContainer = document.getElementById('recurringList');
  if (!recs.length) { recContainer.innerHTML = '<div class="empty-state"><div class="emoji">🔄</div><p>לא זוהו הוצאות חוזרות</p></div>'; return; }
  recContainer.innerHTML = recs.slice(0,5).map(r=>`
    <div class="tx-item">
      <div class="tx-icon" style="background:rgba(108,99,255,0.1)">🔄</div>
      <div class="tx-info">
        <div class="tx-title">${r.desc}</div>
        <div class="tx-meta">${r.count} פעמים · סה"כ ${fmtMoney(r.total)}</div>
      </div>
      <div class="tx-amount exp">${fmtMoney(r.total/r.count)}/פעם</div>
    </div>`).join('');
}

function renderBudget() {
  const global = budgets.global || 0;
  const txs = monthTx(currentMonth());
  const exp = totalExpense(txs);
  document.getElementById('globalBudget').value = global || '';
  document.getElementById('usedBudget').textContent = fmtMoney(exp);

  const pct = global>0 ? Math.min(Math.round(exp/global*100),100) : 0;
  document.getElementById('globalBudgetBar').style.width = pct+'%';
  document.getElementById('globalBudgetBar').className = 'progress-fill ' + (pct>90?'fill-red':pct>70?'fill-yellow':'fill-green');
  document.getElementById('globalBudgetPct').textContent = pct+'% בשימוש';
  document.getElementById('globalBudgetLeft').textContent = 'נשאר: ' + fmtMoney(Math.max(global-exp,0));

  const catMap = expByCat(txs);
  const container = document.getElementById('categoryBudgets');
  container.innerHTML = categories.map(cat=>{
    const spent = catMap[cat.id]||0;
    const budget = budgets.cats[cat.id]||0;
    const pctCat = budget>0 ? Math.min(Math.round(spent/budget*100),100) : 0;
    const fillCls = pctCat>90?'fill-red':pctCat>70?'fill-yellow':'fill-purple';
    return `<div class="progress-item">
      <div class="progress-row">
        <div class="progress-label">${cat.emoji} ${cat.name}</div>
        <div class="progress-vals">${fmtMoney(spent)}${budget>0?' / '+fmtMoney(budget):''}</div>
      </div>
      <div class="progress-track">
        <div class="progress-fill ${fillCls}" style="width:${pctCat}%"></div>
      </div>
      <div style="display:flex;gap:8px;margin-top:6px">
        <input type="number" placeholder="תקציב" value="${budget||''}"
          style="font-size:12px;padding:6px 10px;flex:1"
          onchange="setCatBudget('${cat.id}',this.value)">
      </div>
    </div>`;
  }).join('');
}

function renderInsights() {
  const f = forecast();
  document.getElementById('insightDailyRate').textContent = fmtMoney(f.rate);
  document.getElementById('insightForecastTotal').textContent = fmtMoney(f.projected);

  // recommendations
  const txs = monthTx(currentMonth());
  const catMap = expByCat(txs);
  const recs = [];
  const total = Object.values(catMap).reduce((s,v)=>s+v,0);

  Object.entries(catMap).forEach(([id,val])=>{
    const pct = total>0?val/total:0;
    if (pct>0.3) recs.push({ icon:'⚠️', title:`הוצאה גבוהה ב${getCat(id).name}`, body:`${Math.round(pct*100)}% מסך ההוצאות שלך מגיע מ${getCat(id).name}. שקול לצמצם.` });
    const budget = budgets.cats[id];
    if (budget && val>budget*0.9) recs.push({ icon:'🚨', title:`קרוב לתקציב — ${getCat(id).name}`, body:`השתמשת ב-${fmtMoney(val)} מתוך ${fmtMoney(budget)} שהגדרת.` });
  });

  if (recs.length===0) recs.push({ icon:'✅', title:'מצב תקציב תקין', body:'אין חריגות מזוהות החודש. המשך כך!' });

  const recContainer = document.getElementById('recommendationsList');
  recContainer.innerHTML = recs.map(r=>`
    <div class="rec-card">
      <div class="rec-icon">${r.icon}</div>
      <div><div class="rec-title">${r.title}</div><div class="rec-body">${r.body}</div></div>
    </div>`).join('');

  // patterns
  const recurring = getRecurring();
  const patternsContainer = document.getElementById('patternsList');
  if (!recurring.length) {
    patternsContainer.innerHTML = '<div class="card"><div class="empty-state"><div class="emoji">🔍</div><p>לא זוהו דפוסים</p></div></div>';
    return;
  }
  patternsContainer.innerHTML = '<div class="card">' + recurring.slice(0,4).map(r=>`
    <div class="tx-item">
      <div class="tx-icon" style="background:rgba(56,189,248,0.1)">🔄</div>
      <div class="tx-info">
        <div class="tx-title">${r.desc}</div>
        <div class="tx-meta">חוזר ${r.count} פעמים · ממוצע ${fmtMoney(r.total/r.count)}</div>
      </div>
    </div>`).join('') + '</div>';
}

// ═══════════════════════════════════════════════
//  CHARTS
// ═══════════════════════════════════════════════

const CHART_DEFAULTS = {
  color: 'rgba(255,255,255,0.7)',
  font: { family: 'Heebo', size: 11 }
};

function renderTrendChart() {
  const days = 30;
  const labels = [], data = [];
  for (let i=days-1;i>=0;i--) {
    const d = new Date(); d.setDate(d.getDate()-i);
    const key = d.toISOString().slice(0,10);
    labels.push(d.getDate()+'/'+(d.getMonth()+1));
    data.push(transactions.filter(t=>t.date===key&&t.type==='expense').reduce((s,t)=>s+t.amount,0));
  }
  if (trendChartInst) trendChartInst.destroy();
  const ctx = document.getElementById('trendChart').getContext('2d');
  const grad = ctx.createLinearGradient(0,0,0,160);
  grad.addColorStop(0,'rgba(108,99,255,0.4)');
  grad.addColorStop(1,'rgba(108,99,255,0)');
  trendChartInst = new Chart(ctx, {
    type:'line',
    data:{
      labels,
      datasets:[{
        data, fill:true, backgroundColor:grad,
        borderColor:'#6c63ff', borderWidth:2,
        pointRadius:0, tension:0.4,
        pointHoverRadius:4
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:c=>fmtMoney(c.raw) } } },
      scales:{
        x:{ ticks:{ color:'rgba(255,255,255,0.4)', maxTicksLimit:7, font:CHART_DEFAULTS.font }, grid:{color:'rgba(255,255,255,0.04)'} },
        y:{ ticks:{ color:'rgba(255,255,255,0.4)', callback:v=>fmtMoney(v), font:CHART_DEFAULTS.font }, grid:{color:'rgba(255,255,255,0.06)'} }
      }
    }
  });
}

function renderCompareChart() {
  const months = [];
  for (let i=5;i>=0;i--) {
    const d = new Date(); d.setMonth(d.getMonth()-i);
    months.push(d.toISOString().slice(0,7));
  }
  const incData = months.map(m=>totalIncome(monthTx(m)));
  const expData = months.map(m=>totalExpense(monthTx(m)));
  const labels = months.map(m=>{
    const [y,mo]=m.split('-');
    return ['ינ','פב','מר','אפ','מי','יו','יל','אג','ספ','אק','נו','דצ'][parseInt(mo)-1]+"'"+(y.slice(2));
  });
  if (compareChartInst) compareChartInst.destroy();
  const ctx2 = document.getElementById('compareChart').getContext('2d');
  compareChartInst = new Chart(ctx2, {
    type:'bar',
    data:{
      labels,
      datasets:[
        { label:'הכנסות', data:incData, backgroundColor:'rgba(52,211,153,0.6)', borderRadius:6 },
        { label:'הוצאות', data:expData, backgroundColor:'rgba(248,113,113,0.6)', borderRadius:6 }
      ]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{ labels:{ color:'rgba(255,255,255,0.6)', font:CHART_DEFAULTS.font } }, tooltip:{ callbacks:{ label:c=>` ${fmtMoney(c.raw)}` } } },
      scales:{
        x:{ ticks:{ color:'rgba(255,255,255,0.4)', font:CHART_DEFAULTS.font }, grid:{display:false} },
        y:{ ticks:{ color:'rgba(255,255,255,0.4)', callback:v=>fmtMoney(v), font:CHART_DEFAULTS.font }, grid:{color:'rgba(255,255,255,0.06)'} }
      }
    }
  });
}

