function openSettingsModal() {
  renderCatManageList();
  openModal('settingsModal');
}

function renderCatManageList() {
  const container = document.getElementById('catManageList');
  container.innerHTML = '<div style="margin-bottom:8px;font-size:12px;color:var(--text2);font-weight:700">קטגוריות קיימות</div>' +
    categories.map(c=>`
      <div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)">
        <span style="font-size:18px">${c.emoji}</span>
        <span style="flex:1;font-size:13px;font-weight:600">${c.name}</span>
        ${c.id!=='other'?`<button onclick="deleteCategory('${c.id}')" style="background:rgba(248,113,113,0.15);color:var(--red);border:none;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:12px">מחק</button>`:''}
      </div>`).join('');
}

function addCategory() {
  const name  = document.getElementById('newCatName').value.trim();
  const emoji = document.getElementById('newCatEmoji').value.trim() || '📌';
  if (!name) { showToast('הכנס שם קטגוריה','error'); return; }
  const id = 'cat'+Date.now();
  categories.push({ id, name, emoji });
  save('fm_categories', categories);
  document.getElementById('newCatName').value = '';
  document.getElementById('newCatEmoji').value = '';
  renderCatManageList();
  showToast('קטגוריה נוספה ✓','success');
}

function deleteCategory(id) {
  if (!confirm('למחוק קטגוריה?')) return;
  categories = categories.filter(c=>c.id!==id);
  save('fm_categories', categories);
  renderCatManageList();
  showToast('קטגוריה נמחקה','success');
}

