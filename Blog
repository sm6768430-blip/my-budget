<!DOCTYPE html>

<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FlowMoney — ניהול תזרים חכם</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
  :root {
    --bg: #0a0a0f;
    --bg2: #12121a;
    --bg3: #1a1a26;
    --card: #1e1e2e;
    --card2: #252538;
    --border: #2e2e45;
    --accent: #6c63ff;
    --accent2: #a78bfa;
    --accent3: #38bdf8;
    --green: #34d399;
    --red: #f87171;
    --yellow: #fbbf24;
    --text: #e8e8f0;
    --text2: #9999bb;
    --text3: #5555777;
    --radius: 16px;
    --radius-sm: 10px;
    --shadow: 0 8px 32px rgba(0,0,0,0.4);
    --glow: 0 0 30px rgba(108,99,255,0.15);
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
font-family: ‘Heebo’, sans-serif;
background: var(–bg);
color: var(–text);
min-height: 100vh;
overflow-x: hidden;
direction: rtl;
}

/* ─── LAYOUT ─── */
.app-shell { display: flex; flex-direction: column; min-height: 100vh; max-width: 430px; margin: 0 auto; background: var(–bg); position: relative; }

/* ─── HEADER ─── */
.header {
padding: 20px 20px 0;
background: linear-gradient(180deg, var(–bg2) 0%, transparent 100%);
position: sticky; top: 0; z-index: 50;
}
.header-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
.logo { font-size: 22px; font-weight: 900; background: linear-gradient(135deg, var(–accent) 0%, var(–accent3) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.header-date { font-size: 12px; color: var(–text2); }
.icon-btn { width: 38px; height: 38px; border-radius: 50%; background: var(–card2); border: 1px solid var(–border); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 16px; transition: all .2s; }
.icon-btn:hover { background: var(–accent); border-color: var(–accent); }

/* ─── BALANCE HERO ─── */
.balance-hero {
margin: 16px 20px;
background: linear-gradient(135deg, #1e1e3f 0%, #0f0f25 100%);
border: 1px solid var(–border);
border-radius: 24px;
padding: 24px;
position: relative;
overflow: hidden;
}
.balance-hero::before {
content: ‘’;
position: absolute;
top: -40px; right: -40px;
width: 180px; height: 180px;
background: radial-gradient(circle, rgba(108,99,255,0.2) 0%, transparent 70%);
pointer-events: none;
}
.balance-label { font-size: 12px; color: var(–text2); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
.balance-amount { font-size: 38px; font-weight: 900; letter-spacing: -1px; margin-bottom: 16px; }
.balance-amount.positive { color: var(–green); }
.balance-amount.negative { color: var(–red); }
.balance-row { display: flex; gap: 12px; }
.balance-chip {
flex: 1;
background: rgba(255,255,255,0.05);
border-radius: var(–radius-sm);
padding: 10px 12px;
border: 1px solid rgba(255,255,255,0.06);
}
.balance-chip-label { font-size: 10px; color: var(–text2); margin-bottom: 3px; }
.balance-chip-val { font-size: 15px; font-weight: 700; }
.balance-chip-val.inc { color: var(–green); }
.balance-chip-val.exp { color: var(–red); }

/* ─── NAV ─── */
.tab-nav { display: flex; gap: 4px; padding: 0 20px 12px; overflow-x: auto; scrollbar-width: none; }
.tab-nav::-webkit-scrollbar { display: none; }
.tab-btn {
flex-shrink: 0;
padding: 7px 16px;
border-radius: 20px;
font-size: 13px;
font-weight: 600;
font-family: ‘Heebo’, sans-serif;
cursor: pointer;
border: 1px solid var(–border);
background: var(–card);
color: var(–text2);
transition: all .2s;
white-space: nowrap;
}
.tab-btn.active { background: var(–accent); border-color: var(–accent); color: #fff; box-shadow: 0 4px 16px rgba(108,99,255,0.4); }

/* ─── PAGES ─── */
.page { display: none; padding: 0 20px; animation: fadeIn .25s ease; }
.page.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

/* ─── SECTION TITLE ─── */
.section-title { font-size: 13px; font-weight: 700; color: var(–text2); letter-spacing: 1px; text-transform: uppercase; margin: 20px 0 10px; }

/* ─── CARDS ─── */
.card {
background: var(–card);
border: 1px solid var(–border);
border-radius: var(–radius);
padding: 16px;
margin-bottom: 12px;
box-shadow: var(–shadow);
}
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
.card-title { font-size: 14px; font-weight: 700; }
.card-badge { font-size: 11px; padding: 3px 8px; border-radius: 10px; font-weight: 600; }
.badge-green { background: rgba(52,211,153,0.15); color: var(–green); }
.badge-red { background: rgba(248,113,113,0.15); color: var(–red); }
.badge-blue { background: rgba(56,189,248,0.15); color: var(–accent3); }
.badge-purple { background: rgba(108,99,255,0.15); color: var(–accent); }

/* ─── CHART ─── */
.chart-wrap { position: relative; height: 160px; }

/* ─── PROGRESS BARS ─── */
.progress-item { margin-bottom: 12px; }
.progress-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px; }
.progress-label { font-size: 13px; font-weight: 600; }
.progress-vals { font-size: 11px; color: var(–text2); }
.progress-track { height: 8px; background: var(–bg3); border-radius: 4px; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 4px; transition: width .8s cubic-bezier(.4,0,.2,1); }
.fill-green { background: linear-gradient(90deg, var(–green), #6ee7b7); }
.fill-yellow { background: linear-gradient(90deg, var(–yellow), #fde68a); }
.fill-red { background: linear-gradient(90deg, var(–red), #fca5a5); }
.fill-purple { background: linear-gradient(90deg, var(–accent), var(–accent2)); }

/* ─── TRANSACTION LIST ─── */
.tx-item {
display: flex; align-items: center; gap: 12px;
padding: 12px 0;
border-bottom: 1px solid var(–border);
cursor: pointer;
transition: background .15s;
}
.tx-item:last-child { border-bottom: none; }
.tx-icon { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.tx-info { flex: 1; min-width: 0; }
.tx-title { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tx-meta { font-size: 11px; color: var(–text2); margin-top: 1px; }
.tx-amount { font-size: 15px; font-weight: 700; flex-shrink: 0; }
.tx-amount.inc { color: var(–green); }
.tx-amount.exp { color: var(–red); }

/* ─── INSIGHTS ─── */
.insight-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.insight-card {
background: var(–card2);
border: 1px solid var(–border);
border-radius: var(–radius-sm);
padding: 14px;
}
.insight-icon { font-size: 22px; margin-bottom: 6px; }
.insight-val { font-size: 18px; font-weight: 900; }
.insight-label { font-size: 11px; color: var(–text2); margin-top: 2px; }

/* ─── FAB ─── */
.fab {
position: fixed;
bottom: 80px; left: 50%;
transform: translateX(-50%);
width: 56px; height: 56px;
border-radius: 50%;
background: linear-gradient(135deg, var(–accent), var(–accent3));
border: none;
font-size: 26px;
color: #fff;
cursor: pointer;
box-shadow: 0 8px 30px rgba(108,99,255,0.5);
transition: transform .2s, box-shadow .2s;
z-index: 100;
display: flex; align-items: center; justify-content: center;
}
.fab:hover { transform: translateX(-50%) scale(1.1); box-shadow: 0 12px 40px rgba(108,99,255,0.7); }
.fab:active { transform: translateX(-50%) scale(0.95); }

/* ─── BOTTOM NAV ─── */
.bottom-nav {
position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
width: 100%; max-width: 430px;
background: var(–bg2);
border-top: 1px solid var(–border);
display: flex;
z-index: 90;
padding-bottom: env(safe-area-inset-bottom);
}
.nav-item {
flex: 1; display: flex; flex-direction: column; align-items: center;
padding: 10px 0 8px;
cursor: pointer;
transition: color .2s;
font-size: 20px;
color: var(–text2);
border: none; background: none;
}
.nav-item span { font-size: 10px; margin-top: 2px; font-family: ‘Heebo’, sans-serif; }
.nav-item.active { color: var(–accent); }

/* ─── MODAL ─── */
.modal-overlay {
position: fixed; inset: 0;
background: rgba(0,0,0,0.7);
backdrop-filter: blur(8px);
z-index: 200;
display: none; align-items: flex-end; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
background: var(–bg2);
border: 1px solid var(–border);
border-radius: 24px 24px 0 0;
width: 100%; max-width: 430px;
padding: 24px 24px 40px;
animation: slideUp .3s cubic-bezier(.4,0,.2,1);
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: none; } }
.modal-handle { width: 40px; height: 4px; background: var(–border); border-radius: 2px; margin: 0 auto 20px; }
.modal-title { font-size: 18px; font-weight: 800; margin-bottom: 20px; }

/* ─── FORM ─── */
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.form-group { margin-bottom: 14px; }
.form-group.full { grid-column: 1 / -1; }
label { font-size: 12px; color: var(–text2); font-weight: 600; display: block; margin-bottom: 6px; }
input, select, textarea {
width: 100%;
background: var(–bg3);
border: 1px solid var(–border);
border-radius: var(–radius-sm);
color: var(–text);
font-family: ‘Heebo’, sans-serif;
font-size: 14px;
padding: 10px 14px;
outline: none;
transition: border-color .2s;
direction: rtl;
}
input:focus, select:focus { border-color: var(–accent); box-shadow: 0 0 0 3px rgba(108,99,255,0.15); }
select option { background: var(–bg3); }

/* ─── TYPE TOGGLE ─── */
.type-toggle { display: flex; gap: 8px; margin-bottom: 16px; }
.type-btn {
flex: 1; padding: 10px; border-radius: var(–radius-sm);
border: 1px solid var(–border);
background: var(–bg3);
color: var(–text2);
font-family: ‘Heebo’, sans-serif;
font-size: 14px; font-weight: 700;
cursor: pointer; transition: all .2s;
}
.type-btn.active-inc { background: rgba(52,211,153,0.15); border-color: var(–green); color: var(–green); }
.type-btn.active-exp { background: rgba(248,113,113,0.15); border-color: var(–red); color: var(–red); }

/* ─── BUTTONS ─── */
.btn {
width: 100%; padding: 14px;
border-radius: var(–radius-sm);
border: none; font-family: ‘Heebo’, sans-serif;
font-size: 15px; font-weight: 800;
cursor: pointer; transition: all .2s;
}
.btn-primary { background: linear-gradient(135deg, var(–accent), var(–accent3)); color: #fff; box-shadow: 0 4px 20px rgba(108,99,255,0.4); }
.btn-primary:hover { box-shadow: 0 6px 28px rgba(108,99,255,0.6); transform: translateY(-1px); }
.btn-danger { background: rgba(248,113,113,0.15); color: var(–red); border: 1px solid var(–red); }

/* ─── TAGS ─── */
.tags-wrap { display: flex; flex-wrap: wrap; gap: 6px; }
.tag {
padding: 4px 10px; border-radius: 12px;
background: var(–bg3); border: 1px solid var(–border);
font-size: 11px; color: var(–text2); cursor: pointer; transition: all .15s;
}
.tag.active { background: rgba(108,99,255,0.2); border-color: var(–accent); color: var(–accent2); }

/* ─── SEARCH ─── */
.search-wrap { position: relative; margin-bottom: 12px; }
.search-wrap input { padding-right: 40px; }
.search-icon { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: var(–text2); pointer-events: none; }

/* ─── FILTER ROW ─── */
.filter-row { display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; margin-bottom: 12px; padding-bottom: 4px; }
.filter-row::-webkit-scrollbar { display: none; }
.filter-chip {
flex-shrink: 0; padding: 5px 12px; border-radius: 12px;
border: 1px solid var(–border); background: var(–card);
font-size: 12px; color: var(–text2); cursor: pointer;
transition: all .15s; font-family: ‘Heebo’, sans-serif;
}
.filter-chip.active { background: var(–accent); border-color: var(–accent); color: #fff; }

/* ─── FORECAST ─── */
.forecast-bar {
background: linear-gradient(135deg, rgba(108,99,255,0.1) 0%, rgba(56,189,248,0.1) 100%);
border: 1px solid rgba(108,99,255,0.3);
border-radius: var(–radius);
padding: 16px;
margin-bottom: 12px;
}
.forecast-row { display: flex; justify-content: space-between; align-items: center; }
.forecast-label { font-size: 12px; color: var(–text2); }
.forecast-val { font-size: 20px; font-weight: 900; color: var(–accent2); }
.forecast-sub { font-size: 11px; color: var(–text2); margin-top: 4px; }

/* ─── EMPTY STATE ─── */
.empty-state { text-align: center; padding: 40px 20px; color: var(–text2); }
.empty-state .emoji { font-size: 48px; margin-bottom: 12px; }
.empty-state p { font-size: 14px; }

/* ─── TOAST ─── */
.toast {
position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
background: var(–card2);
border: 1px solid var(–border);
border-radius: 12px;
padding: 12px 20px;
font-size: 13px; font-weight: 600;
z-index: 999;
opacity: 0; pointer-events: none;
transition: opacity .3s, top .3s;
white-space: nowrap;
}
.toast.show { opacity: 1; top: 30px; }
.toast.success { border-color: var(–green); color: var(–green); }
.toast.error { border-color: var(–red); color: var(–red); }

/* ─── SCROLLABLE CONTENT ─── */
.scroll-content { padding-bottom: 130px; }

/* ─── DONUT LEGEND ─── */
.legend-list { margin-top: 12px; }
.legend-item { display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: 1px solid var(–border); }
.legend-item:last-child { border-bottom: none; }
.legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.legend-name { flex: 1; font-size: 13px; }
.legend-pct { font-size: 12px; color: var(–text2); }
.legend-val { font-size: 13px; font-weight: 700; }

/* ─── BUDGET SETTINGS ─── */
.budget-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.budget-input-card {
background: var(–bg3); border: 1px solid var(–border); border-radius: var(–radius-sm);
padding: 10px 12px;
}
.budget-input-card label { font-size: 11px; color: var(–text2); margin-bottom: 4px; }
.budget-input-card input { background: transparent; border: none; font-size: 16px; font-weight: 700; padding: 0; }

/* ─── RECOMMENDATION ─── */
.rec-card {
display: flex; gap: 12px; align-items: flex-start;
background: var(–card2); border: 1px solid var(–border);
border-radius: var(–radius-sm); padding: 14px; margin-bottom: 10px;
}
.rec-icon { font-size: 24px; }
.rec-title { font-size: 13px; font-weight: 700; margin-bottom: 3px; }
.rec-body { font-size: 12px; color: var(–text2); line-height: 1.5; }

/* ─── DELETE ACTION ─── */
.tx-actions { display: flex; gap: 8px; margin-top: 8px; }
.action-btn { flex: 1; padding: 8px; border-radius: 8px; border: none; font-family: ‘Heebo’, sans-serif; font-size: 13px; font-weight: 700; cursor: pointer; }
.action-edit { background: rgba(108,99,255,0.15); color: var(–accent2); }
.action-del { background: rgba(248,113,113,0.15); color: var(–red); }

/* ─── DONUT CHART CENTER TEXT ─── */
.donut-wrap { position: relative; }
.donut-center {
position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
text-align: center; pointer-events: none;
}
.donut-center-val { font-size: 20px; font-weight: 900; }
.donut-center-label { font-size: 11px; color: var(–text2); }
</style>

</head>
