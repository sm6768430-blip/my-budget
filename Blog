const TAB_PAGE_MAP = { dashboard:'dashboard', transactions:'transactions', analysis:'analysis', budget:'budget', insights:'insights' };

function switchTab(page, btn) {
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  document.querySelectorAll('.nav-item').forEach((b,i)=>{
    const pages=['dashboard','transactions','analysis','budget','insights'];
    b.classList.toggle('active', pages[i]===page);
  });
  renderAll();
}

function switchNav(page, btn) {
  document.querySelectorAll('.nav-item').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  document.querySelectorAll('.tab-btn').forEach(b=>{
    b.classList.toggle('active', b.textContent===({dashboard:'דשבורד',transactions:'תנועות',analysis:'ניתוח',budget:'תקציב',insights:'תובנות'}[page]));
  });
  renderAll();
}

// ═══════════════════════════════════════════════
//  MODAL
// ═══════════════════════════════════════════════

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.modal-overlay').forEach(m=>{
  m.addEventListener('click', e=>{ if(e.target===m) m.classList.remove('open'); });
});

function openAddModal() {
  editingId = null;
  document.getElementById('modalTitle').textContent = 'הוסף תנועה';
  document.getElementById('txAmount').value = '';
  document.getElementById('txDate').value = today();
  document.getElementById('txDesc').value = '';
  document.getElementById('editId').value = '';
  document.getElementById('deleteBtn').style.display = 'none';
  setType('expense');
  populateCategorySelect();
  renderTagsWrap([]);
  openModal('addModal');
}

function openEditModal(id) {
  const t = transactions.find(x=>x.id===id);
  if (!t) return;
  editingId = id;
  document.getElementById('modalTitle').textContent = 'עריכת תנועה';
  document.getElementById('txAmount').value = t.amount;
  document.getElementById('txDate').value = t.date;
  document.getElementById('txDesc').value = t.description || '';
  document.getElementById('editId').value = id;
  document.getElementById('deleteBtn').style.display = 'block';
  setType(t.type);
  populateCategorySelect(t.category);
  renderTagsWrap(t.tags||[]);
  openModal('addModal');
}

function setType(type) {
  currentType = type;
  const btnI = document.getElementById('btnIncome');
  const btnE = document.getElementById('btnExpense');
  btnI.className = 'type-btn' + (type==='income'?' active-inc':'');
  btnE.className = 'type-btn' + (type==='expense'?' active-exp':'');
}

function populateCategorySelect(selected) {
  const sel = document.getElementById('txCategory');
  sel.innerHTML = categories.map(c=>`<option value="${c.id}" ${c.id===selected?'selected':''}>${c.emoji} ${c.name}</option>`).join('');
}

let activeTags = [];
function renderTagsWrap(tags) {
  activeTags = [...tags];
  const wrap = document.getElementById('tagsWrap');
  wrap.innerHTML = TAGS.map(t=>`<span class="tag ${activeTags.includes(t)?'active':''}" onclick="toggleTag('${t}')">${t}</span>`).join('');
}
function toggleTag(tag) {
  if (activeTags.includes(tag)) activeTags=activeTags.filter(t=>t!==tag);
  else activeTags.push(tag);
  renderTagsWrap(activeTags);
}

function saveTransaction() {
  const amount = parseFloat(document.getElementById('txAmount').value);
  const date   = document.getElementById('txDate').value;
  const desc   = document.getElementById('txDesc').value.trim();
  const cat    = document.getElementById('txCategory').value;
  if (!amount || amount<=0) { showToast('הכנס סכום תקין','error'); return; }
  if (!date) { showToast('הכנס תאריך','error'); return; }

  if (editingId) {
    const idx = transactions.findIndex(t=>t.id===editingId);
    transactions[idx] = { ...transactions[idx], amount, date, description:desc, category:cat, type:currentType, tags:activeTags };
    showToast('תנועה עודכנה ✓','success');
  } else {
    transactions.push({ id: 'tx'+Date.now(), amount, date, description:desc, category:cat, type:currentType, tags:activeTags, createdAt: nowMs() });
    showToast('תנועה נוספה ✓','success');
  }
  save('fm_transactions', transactions);
  closeModal('addModal');
  renderAll();
}

function deleteTransaction() {
  if (!editingId) return;
  if (!confirm('למחוק את התנועה?')) return;
  transactions = transactions.filter(t=>t.id!==editingId);
  save('fm_transactions', transactions);
  closeModal('addModal');
  showToast('תנועה נמחקה','success');
  renderAll();
}

