// ═══════════════════════════════════════════════

function exportJSON() {
  const data = { transactions, categories, budgets, exportDate: new Date().toISOString() };
  const blob = new Blob([JSON.stringify(data,null,2)], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href=url; a.download='flowmoney_backup.json'; a.click();
  showToast('ייצוא הצליח 📤','success');
}

function exportCSV() {
  const rows = [['תאריך','סוג','קטגוריה','תיאור','סכום','תגיות']];
  transactions.forEach(t=>{
    rows.push([t.date, t.type==='income'?'הכנסה':'הוצאה', getCat(t.category).name, t.description, t.amount, (t.tags||[]).join(';')]);
  });
  const csv = rows.map(r=>r.join(',')).join('\n');
  const blob = new Blob(['\ufeff'+csv], {type:'text/csv;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href=url; a.download='flowmoney_export.csv'; a.click();
  showToast('CSV יוצא בהצלחה 📊','success');
}

function importJSON(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    try {
      const data = JSON.parse(ev.target.result);
      if (data.transactions) { transactions = data.transactions; save('fm_transactions', transactions); }
      if (data.categories)   { categories = data.categories; save('fm_categories', categories); }
      if (data.budgets)      { budgets = data.budgets; save('fm_budgets', budgets); }
      showToast('ייבוא הצליח ✓','success');
      renderAll();
    } catch { showToast('שגיאה בקובץ JSON','error'); }
  };
  reader.readAsText(file);
}

function clearAllData() {
  if (!confirm('למחוק את כל הנתונים? פעולה זו אינה הפיכה!')) return;
  transactions = []; categories = [...DEFAULT_CATEGORIES]; budgets = { global:0, cats:{} };
  save('fm_transactions', transactions);
  save('fm_categories', categories);
  save('fm_budgets', budgets);
  showToast('כל הנתונים נמחקו','success');
  closeModal('settingsModal');
  renderAll();
}

